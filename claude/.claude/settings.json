{
  "cleanupPeriodDays": 365,
  "permissions": {
    "defaultMode": "plan"
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|auth_success|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "sh ~/.claude/bin/notify-bell.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/bin/statusline.sh",
    "padding": 0
  },
  "alwaysThinkingEnabled": true
}
