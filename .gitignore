/emacs/.emacs.d/*
!/emacs/.emacs.d/early-init.el
!/emacs/.emacs.d/init.el
!/emacs/.emacs.d/lisp

/mpv/.config/mpv/*
!/mpv/.config/mpv/input.conf
!/mpv/.config/mpv/mpv.conf
!/mpv/.config/mpv/scripts

/claude/.claude/*
!/claude/.claude/settings.json
!/claude/.claude/statusline.sh
!/claude/.claude/hooks
